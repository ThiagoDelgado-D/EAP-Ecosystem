{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "rootDir": "src",
        "outDir": "dist",
        "declaration": true,
        "declarationMap": true,
        "paths": {
            "domain-lib": [
                "shared/domain-lib/dist/index.d.ts"
            ],
            "infrastructure-lib": [
                "shared/infrastructure-lib/dist/index.d.ts"
            ],
            "@learning-resource/domain": [
                "learning-resource/domain/dist/index.d.ts"
            ]
        }
    },
    "exclude": [
        "dist",
        "node_modules"
    ]
}