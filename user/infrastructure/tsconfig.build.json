{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "domain-lib": ["shared/domain-lib/dist/index.d.ts"],
      "@user/domain": ["user/domain/dist/index.d.ts"]
    }
  },
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.spec.ts"
  ]
}
