{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "apps/api/src/main",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "emails/**/*.hbs",
        "outDir": "./dist/apps/api/src",
        "watchAssets": true
      }
    ]
  }
}