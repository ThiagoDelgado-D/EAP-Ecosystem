<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to EAP</title>
  </head>
  <body
    style="margin:0;padding:0;background:#020617;font-family:'Inter','Segoe UI',Arial,sans-serif;"
  >

    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="background:#020617;padding:40px 16px;"
    >
      <tr>
        <td align="center">

          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="max-width:560px;background:#0f172a;border-radius:16px;
                      border:1px solid #1e293b;overflow:hidden;"
          >

            <!-- Body -->
            <tr>
              <td style="padding:40px 36px 32px;">

                <!-- Brand -->
                <p style="margin:0 0 28px;font-size:13px;font-weight:700;
                           color:#f1f5f9;letter-spacing:0.05em;">
                  EAP <span style="color:#a78bfa;letter-spacing:0.15em;">ECOSYSTEM</span>
                </p>

                <h1 style="margin:0 0 10px;font-size:22px;font-weight:700;color:#f1f5f9;
                            line-height:1.3;">
                  Welcome{{#if firstName}}, {{firstName}}{{/if}} 👋
                </h1>
                <p style="margin:0 0 16px;font-size:14px;color:#64748b;line-height:1.6;">
                  Your EAP account is ready. Start building your personal
                  learning ecosystem — catalog resources, track your progress,
                  and let EAP surface what to study based on your energy and
                  focus.
                </p>
                <p style="margin:0;font-size:13px;color:#334155;line-height:1.6;">
                  Head back to the app to complete your setup and add your first
                  resource.
                </p>

              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="background:#080f1f;padding:16px 36px;border-top:1px solid #1e293b;"
              >
                <p style="margin:0;font-size:11px;color:#334155;text-align:center;">
                  © {{year}} EAP Ecosystem · Personal learning, your way
                </p>
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>
</html>
