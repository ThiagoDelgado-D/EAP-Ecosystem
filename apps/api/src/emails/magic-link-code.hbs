<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your EAP sign-in code</title>
  </head>
  <body
    style="margin:0;padding:0;background:#020617;font-family:'Inter','Segoe UI',Arial,sans-serif;"
  >

    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="background:#020617;padding:40px 16px;"
    >
      <tr>
        <td align="center">

          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="max-width:560px;background:#0f172a;border-radius:16px;
                      border:1px solid #1e293b;overflow:hidden;"
          >

            <!-- Body -->
            <tr>
              <td style="padding:40px 36px 32px;">

                <!-- Brand -->
                <p style="margin:0 0 28px;font-size:13px;font-weight:700;
                           color:#f1f5f9;letter-spacing:0.05em;">
                  EAP <span style="color:#a78bfa;letter-spacing:0.15em;">ECOSYSTEM</span>
                </p>

                <h1 style="margin:0 0 10px;font-size:22px;font-weight:700;color:#f1f5f9;
                            line-height:1.3;">
                  Your sign-in code
                </h1>
                <p style="margin:0 0 28px;font-size:14px;color:#64748b;line-height:1.6;">
                  Use the code below to sign in to EAP. It expires in
                  <span style="color:#e2e8f0;font-weight:600;">10 minutes</span>.
                </p>

                <!-- Code box -->
                <table cellpadding="0" cellspacing="0" style="margin:0 auto 28px;">
                  <tr>
                    <td
                      style="background:#1e1b4b;border:2px dashed #7c3aed;
                              border-radius:12px;padding:20px 40px;text-align:center;"
                    >
                      <span
                        style="font-family:'Courier New',Courier,monospace;
                               font-size:34px;font-weight:700;color:#ede9fe;
                               letter-spacing:10px;"
                      >
                        {{code}}
                      </span>
                    </td>
                  </tr>
                </table>

                <p style="margin:0;font-size:12px;color:#334155;line-height:1.6;">
                  If you didn't request this code, you can safely ignore this
                  email. Someone may have entered your address by mistake.
                </p>

              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="background:#080f1f;padding:16px 36px;border-top:1px solid #1e293b;"
              >
                <p style="margin:0;font-size:11px;color:#334155;text-align:center;">
                  © {{year}} EAP Ecosystem · Personal learning, your way
                </p>
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>
</html>
