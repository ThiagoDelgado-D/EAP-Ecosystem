# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=eap_user
DB_PASSWORD=change_me
DB_NAME=eap_db

# ── CORS ───────────────────────────────────────────────────────────────────────
# Origin allowed to call the API (Angular dev server or production domain)
CORS_ORIGIN=http://localhost:4200

# ── Application ────────────────────────────────────────────────────────────────
# Full public URL of the web frontend (used in email links)
WEB_HOST=http://localhost:4200

# ── JWT ────────────────────────────────────────────────────────────────────────
# Secret used to sign access tokens — use a long random string in production
JWT_SECRET=change_me_use_a_long_random_secret
# Access token TTL (ms or zeit/ms string: "15m", "1h", etc.)
JWT_EXPIRES_IN=15m
# Refresh token TTL in days
REFRESH_TOKEN_EXPIRES_DAYS=30

# ── SMTP (required for Magic Link auth) ────────────────────────────────────────
# Any SMTP provider works: Gmail, Resend, Mailgun, Postmark, self-hosted, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=change_me
# "From" address shown in outgoing emails
SMTP_FROM=noreply@example.com
